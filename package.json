{
  "name": "holodos-ai",
  "private": true,
  "version": "3.5.1",
  "description": "Smart Fridge & AI Grocery Assistant",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "node scripts/update-version.js && tsc -b && vite build",
    "postinstall": "node scripts/patch-google-auth.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify": "npm run build && vite preview --host",
    "cap:sync": "npm run build && npx cap sync",
    "build:ru": "vite build --mode ru",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "mobile:prepare": "npm run build && (npx cap sync ios && npx cap sync android)",
    "mobile:ios": "npm run build && npx cap copy ios && npx cap open ios",
    "mobile:android": "npm run build && npx cap copy android && npx cap open android",
    "deploy": "node scripts/deploy-yandex.js",
    "deploy:apk": "chmod +x scripts/deploy-apk.sh && bash scripts/deploy-apk.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-health": "^8.4.2",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "firebase": "^12.11.0",
    "heic2any": "^0.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.12.0",
    "globals": "^17.4.0",
    "terser": "^5.46.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
